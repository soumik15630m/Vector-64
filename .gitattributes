# Normalize line endings: store text as LF in the repo, check out native.
# Shell scripts stay LF everywhere so they run on POSIX hosts.
* text=auto eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf

# Binary assets — never diffed or line-ending converted.
*.nnue binary
*.npz binary
*.pt binary
*.bin binary
