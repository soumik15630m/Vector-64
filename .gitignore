# ---- build directories ----
/build/
/build-*/
/cmake-build-*/
/out/
/CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CMakeUserPresets.json
compile_commands.json
Makefile

# ---- compiled objects / binaries / libs ----
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib
*.exe
*.pdb
*.ilk
*.exp

# ---- profile-guided optimization artifacts ----
*.gcda
*.gcno
*.gcov
gmon.out

# ---- python ----
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# ---- training data, checkpoints, networks (loaded at runtime, never tracked) ----
/artifacts/
/tools/data/
*.nnue
*.npz
*.pt
*.ckpt
*.meta.json

# ---- editors / IDEs ----
/.idea/
/.vscode/
*.swp

# ---- OS cruft ----
.DS_Store
Thumbs.db

# ---- logs / temp ----
*.log
*.tmp
*.cache
runs/
*.jsonl.zst
